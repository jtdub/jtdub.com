# Substack email publishing address (from Substack dashboard: Settings > Publishing)
SUBSTACK_EMAIL_ADDRESS=your-secret-address@substack.com

# SMTP settings (configured for Proton Mail Bridge)
# Proton Mail Bridge must be running locally for SMTP to work.
# See: https://proton.me/mail/bridge
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=some.user@example.com
SMTP_PASSWORD=your-bridge-password
