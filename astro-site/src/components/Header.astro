---
interface Props {
  zone?: 'field' | 'engineering' | 'home';
}
const { zone = 'home' } = Astro.props;
---

<header class="site-header" data-zone={zone === 'home' ? undefined : zone}>
  <div class="site-header__inner">
    <a href="/" class="site-header__wordmark" aria-label="jtdub.com home">
      <span class="site-header__mark">jtdub</span>
      <span class="site-header__dot">.</span>
      <span class="site-header__tld">com</span>
    </a>

    <nav class="site-header__nav" id="primary-nav" aria-label="Primary">
      <a href="/field">Field</a>
      <a href="/engineering">Engineering</a>
      <a href="/writing">Writing</a>
      <a href="/about">About</a>
    </nav>

    <div class="site-header__actions">
      <a href="/search" class="site-header__search" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span class="site-header__search-label">Search</span>
      </a>

      <button
        type="button"
        class="site-header__menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="primary-nav"
      >
        <svg class="site-header__menu-icon" width="22" height="16" viewBox="0 0 22 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <line x1="0" y1="1" x2="22" y2="1" />
          <line x1="0" y1="8" x2="22" y2="8" />
          <line x1="0" y1="15" x2="22" y2="15" />
        </svg>
        <svg class="site-header__close-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="display:none">
          <line x1="4" y1="4" x2="20" y2="20" />
          <line x1="20" y1="4" x2="4" y2="20" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const btn = document.querySelector('.site-header__menu-btn');
  const nav = document.getElementById('primary-nav');
  const menuIcon = document.querySelector('.site-header__menu-icon') as HTMLElement;
  const closeIcon = document.querySelector('.site-header__close-icon') as HTMLElement;

  btn?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    if (menuIcon && closeIcon) {
      menuIcon.style.display = isOpen ? 'none' : '';
      closeIcon.style.display = isOpen ? '' : 'none';
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 247, 242, 0.92);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--rule);
  }

  .site-header__inner {
    max-width: var(--shell-max);
    margin: 0 auto;
    padding: var(--space-4) var(--gutter);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-7);
  }

  .site-header__wordmark {
    font-family: var(--font-serif);
    font-size: var(--step-3);
    font-weight: 500;
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    color: var(--ink);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
    display: inline-flex;
    align-items: baseline;
  }

  .site-header__wordmark:hover {
    text-decoration: none;
  }

  .site-header__dot {
    color: var(--accent);
  }

  .site-header__tld {
    color: var(--ink-faint);
    font-style: italic;
  }

  .site-header__nav {
    display: flex;
    gap: var(--space-6);
    justify-content: center;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    font-weight: 500;
  }

  .site-header__nav a {
    color: var(--ink-soft);
    padding: var(--space-2) 0;
    border-bottom: 1px solid transparent;
    transition: color 120ms ease, border-color 120ms ease;
  }

  .site-header__nav a:hover {
    color: var(--ink);
    text-decoration: none;
    border-bottom-color: var(--accent);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .site-header__search {
    background: none;
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--ink-soft);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
    letter-spacing: var(--tracking-snug);
    transition: border-color 120ms ease, color 120ms ease;
  }

  .site-header__search:hover {
    border-color: var(--ink);
    color: var(--ink);
  }

  .site-header__menu-btn {
    display: none;
    background: none;
    border: none;
    padding: var(--space-2);
    color: var(--ink);
    cursor: pointer;
    line-height: 0;
  }

  /* Mobile */
  @media (max-width: 720px) {
    .site-header__inner {
      grid-template-columns: auto auto;
      gap: var(--space-4);
    }

    .site-header__nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--paper);
      border-bottom: 1px solid var(--rule);
      flex-direction: column;
      padding: var(--space-5) var(--gutter) var(--space-6);
      gap: 0;
      box-shadow: 0 12px 32px rgba(22, 20, 18, 0.08);
    }

    .site-header__nav.is-open {
      display: flex;
    }

    .site-header__nav a {
      padding: var(--space-4) 0;
      border-bottom: 1px solid var(--rule);
      font-size: var(--step-0);
    }

    .site-header__nav a:last-child {
      border-bottom: none;
    }

    .site-header__search-label {
      display: none;
    }

    .site-header__search {
      border: none;
      padding: var(--space-2);
    }

    .site-header__menu-btn {
      display: inline-flex;
    }
  }
</style>
