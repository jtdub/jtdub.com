---
import BaseLayout from '../../layouts/BaseLayout.astro';
import photosRaw from '../../data/photos.json';

// Transform year-keyed object into flat array sorted by year desc.
const photos = Object.entries(photosRaw as Record<string, any[]>)
  .flatMap(([year, items]) => items.map((p: any) => ({ ...p, year: Number(year) })))
  .sort((a, b) => b.year - a.year);

const years = [...new Set(photos.map((p) => p.year))].sort((a, b) => b - a);
---

<BaseLayout title="Photography — jtdub.com" zone="field">
  <section class="photo-page" data-zone="field">
    <header class="photo-page__header">
      <p class="photo-page__eyebrow">Field &amp; Research</p>
      <h1 class="photo-page__title">Photography</h1>
      <p class="photo-page__count">{photos.length} photos across {years.length} years</p>
    </header>

    {years.map((year) => (
      <div class="photo-page__year">
        <h2>{year}</h2>
        <div class="photo-page__grid">
          {photos
            .filter((p) => p.year === year)
            .map((p) => (
              <figure class="photo-page__item">
                <a
                  href={p.url}
                  class="photo-page__link"
                  data-lightbox
                  data-title={p.title}
                  data-desc={p.description || ''}
                >
                  <img
                    src={p.url.replace('/public', '/w=640,fit=cover')}
                    alt={p.description || p.title}
                    loading="lazy"
                    decoding="async"
                    width="640"
                    height="480"
                  />
                </a>
                <figcaption>
                  <span class="photo-page__photo-title">{p.title}</span>
                  {p.description && p.description !== p.title && (
                    <span class="photo-page__photo-desc">{p.description}</span>
                  )}
                </figcaption>
              </figure>
            ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  .photo-page {
    max-width: var(--shell-max);
    margin: 0 auto;
    padding: var(--space-9) var(--gutter) var(--space-10);
  }

  .photo-page__header {
    margin-bottom: var(--space-10);
  }

  .photo-page__eyebrow {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .photo-page__title {
    font-family: var(--font-serif);
    font-size: clamp(var(--step-4), 5vw, var(--step-6));
    font-weight: 400;
    letter-spacing: var(--tracking-tight);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
    margin-bottom: var(--space-3);
  }

  .photo-page__count {
    font-family: var(--font-sans);
    font-size: var(--step-1);
    color: var(--ink-faint);
  }

  .photo-page__year {
    margin-bottom: var(--space-9);
  }

  .photo-page__year > h2 {
    font-family: var(--font-serif);
    font-size: var(--step-5);
    font-weight: 300;
    color: var(--accent);
    letter-spacing: var(--tracking-tight);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule);
  }

  .photo-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-5);
  }

  .photo-page__item {
    margin: 0;
  }

  .photo-page__link {
    display: block;
    cursor: zoom-in;
  }

  .photo-page__link:hover {
    text-decoration: none;
  }

  .photo-page__item img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 2px;
    filter: saturate(0.9) contrast(1.02);
    transition: filter 240ms ease, transform 240ms ease;
  }

  .photo-page__item:hover img {
    filter: saturate(1.05) contrast(1.04);
    transform: scale(1.01);
  }

  /* Lightbox overlay */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(22, 20, 18, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
    cursor: zoom-out;
    opacity: 0;
    visibility: hidden;
    transition: opacity 200ms ease, visibility 200ms ease;
  }

  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
  }

  .lightbox__img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 2px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
  }

  .lightbox__caption {
    margin-top: var(--space-4);
    text-align: center;
    color: var(--paper);
  }

  .lightbox__title {
    font-family: var(--font-serif);
    font-size: var(--step-2);
    font-weight: 500;
    font-variation-settings: 'opsz' 144, 'SOFT' 40;
  }

  .lightbox__desc {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--paper-deep);
    margin-top: var(--space-1);
  }

  .lightbox__close {
    position: absolute;
    top: var(--space-5);
    right: var(--space-5);
    background: none;
    border: none;
    color: var(--paper);
    cursor: pointer;
    padding: var(--space-2);
    line-height: 0;
    opacity: 0.7;
    transition: opacity 120ms ease;
  }

  .lightbox__close:hover {
    opacity: 1;
  }

  .photo-page__item figcaption {
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .photo-page__photo-title {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    font-weight: 500;
    color: var(--ink);
    font-variation-settings: 'opsz' 144, 'SOFT' 40;
  }

  .photo-page__photo-desc {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--ink-faint);
  }
</style>

<div class="lightbox" id="lightbox">
  <button type="button" class="lightbox__close" aria-label="Close">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <line x1="4" y1="4" x2="20" y2="20" /><line x1="20" y1="4" x2="4" y2="20" />
    </svg>
  </button>
  <button type="button" class="lightbox__prev" aria-label="Previous photo">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <polyline points="15 18 9 12 15 6" />
    </svg>
  </button>
  <button type="button" class="lightbox__next" aria-label="Next photo">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <polyline points="9 6 15 12 9 18" />
    </svg>
  </button>
  <img class="lightbox__img" src="" alt="" />
  <div class="lightbox__caption">
    <div class="lightbox__title"></div>
    <div class="lightbox__desc"></div>
    <div class="lightbox__counter"></div>
  </div>
</div>

<style>
  .lightbox__prev,
  .lightbox__next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--paper);
    cursor: pointer;
    padding: var(--space-4);
    line-height: 0;
    opacity: 0.6;
    transition: opacity 120ms ease;
    z-index: 1;
  }

  .lightbox__prev:hover,
  .lightbox__next:hover {
    opacity: 1;
  }

  .lightbox__prev { left: var(--space-4); }
  .lightbox__next { right: var(--space-4); }

  .lightbox__counter {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--paper-deep);
    margin-top: var(--space-2);
    font-variant-numeric: tabular-nums;
    opacity: 0.6;
  }
</style>

<script is:inline>
  (function () {
    var lb = document.getElementById('lightbox');
    var lbImg = lb.querySelector('.lightbox__img');
    var lbTitle = lb.querySelector('.lightbox__title');
    var lbDesc = lb.querySelector('.lightbox__desc');
    var lbCounter = lb.querySelector('.lightbox__counter');
    var lbClose = lb.querySelector('.lightbox__close');
    var lbPrev = lb.querySelector('.lightbox__prev');
    var lbNext = lb.querySelector('.lightbox__next');

    var links = Array.from(document.querySelectorAll('[data-lightbox]'));
    var current = 0;

    function show(index) {
      if (index < 0) index = links.length - 1;
      if (index >= links.length) index = 0;
      current = index;
      var link = links[current];
      lbImg.src = link.href;
      lbImg.alt = link.querySelector('img').alt;
      lbTitle.textContent = link.dataset.title || '';
      lbDesc.textContent = link.dataset.desc || '';
      lbCounter.textContent = (current + 1) + ' / ' + links.length;
    }

    function open(index) {
      show(index);
      lb.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lb.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    links.forEach(function (link, i) {
      link.addEventListener('click', function (e) {
        e.preventDefault();
        open(i);
      });
    });

    lbPrev.addEventListener('click', function (e) { e.stopPropagation(); show(current - 1); });
    lbNext.addEventListener('click', function (e) { e.stopPropagation(); show(current + 1); });

    lb.addEventListener('click', function (e) {
      if (e.target === lb || e.target === lbClose || lbClose.contains(e.target)) close();
    });

    document.addEventListener('keydown', function (e) {
      if (!lb.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  })();
</script>
