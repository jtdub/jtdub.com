---
import BaseLayout from '../../layouts/BaseLayout.astro';
import apps from '../../data/projects-apps.json';
---

<BaseLayout
  title="Apps — jtdub.com"
  description="iOS and macOS apps for on-device AI, field research, expedition planning, and high-altitude health monitoring."
>
  <section class="apps-page">
    <header class="apps-page__header">
      <p class="apps-page__eyebrow">Apps</p>
      <h1 class="apps-page__title">Apps</h1>
      <p class="apps-page__lede">
        iOS and macOS apps focused on field research, on-device AI, and tools
        for remote environments.
      </p>
    </header>

    <div class="apps-page__grid">
      {apps.map((a: any) => (
        <div class="apps-page__card">
          <h2>{a.name}</h2>
          <p class="apps-page__desc">{a.description}</p>
          <div class="apps-page__links">
            {a.repo && <a href={a.repo}>Source</a>}
            {a.app_store_url && a.app_store_url !== '#' && (
              <a href={a.app_store_url}>App Store</a>
            )}
            {a.slug && <a href={`/apps/privacy/${a.slug}`}>Privacy</a>}
            {a.slug && <a href={`/apps/support/${a.slug}`}>Support</a>}
          </div>
          <div class="apps-page__meta">
            {a.platforms?.join(' · ')}
            {a.source === 'open' && ' · Open Source'}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .apps-page {
    max-width: var(--shell-max);
    margin: 0 auto;
    padding: var(--space-9) var(--gutter) var(--space-10);
  }

  .apps-page__header {
    margin-bottom: var(--space-9);
  }

  .apps-page__eyebrow {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--ink-faint);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .apps-page__title {
    font-family: var(--font-serif);
    font-size: clamp(var(--step-4), 5vw, var(--step-6));
    font-weight: 400;
    letter-spacing: var(--tracking-tight);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
    margin-bottom: var(--space-5);
  }

  .apps-page__lede {
    font-family: var(--font-serif);
    font-size: var(--step-2);
    line-height: var(--leading-relaxed);
    color: var(--ink-soft);
    max-width: var(--measure);
  }

  .apps-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-5);
  }

  .apps-page__card {
    padding: var(--space-6);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color 180ms ease;
  }

  .apps-page__card:hover {
    border-color: var(--accent);
  }

  .apps-page__card h2 {
    font-family: var(--font-serif);
    font-size: var(--step-3);
    font-weight: 500;
    font-variation-settings: 'opsz' 144, 'SOFT' 40;
  }

  .apps-page__desc {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    line-height: var(--leading-relaxed);
    color: var(--ink-soft);
  }

  .apps-page__links {
    display: flex;
    gap: var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    font-weight: 600;
  }

  .apps-page__links a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .apps-page__meta {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--ink-faint);
    margin-top: auto;
  }
</style>
