<div class="search-modal" id="search-modal" aria-hidden="true" role="dialog" aria-label="Search">
  <div class="search-modal__backdrop" id="search-backdrop"></div>
  <div class="search-modal__panel">
    <div class="search-modal__header">
      <span class="search-modal__label">Search</span>
      <button type="button" class="search-modal__close" id="search-close" aria-label="Close search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <line x1="4" y1="4" x2="20" y2="20" /><line x1="20" y1="4" x2="4" y2="20" />
        </svg>
      </button>
    </div>
    <div id="search-modal-container"></div>
  </div>
</div>

<script is:inline>
  (function () {
    var modal = document.getElementById('search-modal');
    var container = document.getElementById('search-modal-container');
    var openBtn = document.getElementById('search-open');
    var closeBtn = document.getElementById('search-close');
    var backdrop = document.getElementById('search-backdrop');
    var initialized = false;
    var assetsLoaded = false;

    function loadAssets(cb) {
      if (assetsLoaded) { cb(); return; }
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(link);

      var script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = function () { assetsLoaded = true; cb(); };
      document.head.appendChild(script);
    }

    function initUI() {
      if (!initialized && typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: '#search-modal-container',
          showSubResults: true,
          showImages: false,
          autofocus: true,
        });
        initialized = true;
      }
    }

    function open() {
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      loadAssets(function () {
        initUI();
        setTimeout(function () {
          var input = container.querySelector('.pagefind-ui__search-input');
          if (input) { input.focus(); input.select(); }
        }, 50);
      });
    }

    function close() {
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    if (openBtn) openBtn.addEventListener('click', open);
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (backdrop) backdrop.addEventListener('click', close);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') close();
      if ((e.key === '/' || (e.key === 'k' && (e.metaKey || e.ctrlKey))) && modal.getAttribute('aria-hidden') === 'true') {
        e.preventDefault();
        open();
      }
    });
  })();
</script>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
    transition: opacity 180ms ease, visibility 180ms ease;
  }

  .search-modal[aria-hidden='true'] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .search-modal[aria-hidden='false'] {
    opacity: 1;
    visibility: visible;
  }

  .search-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(22, 20, 18, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .search-modal__panel {
    position: relative;
    width: min(640px, calc(100vw - 2 * var(--gutter)));
    max-height: 70vh;
    background: var(--paper);
    border: 1px solid var(--rule);
    box-shadow: 0 24px 64px rgba(22, 20, 18, 0.18);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .search-modal__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--rule);
    flex-shrink: 0;
  }

  .search-modal__label {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--ink-faint);
    font-weight: 600;
  }

  .search-modal__close {
    background: none;
    border: none;
    color: var(--ink-faint);
    cursor: pointer;
    padding: var(--space-2);
    line-height: 0;
    transition: color 120ms ease;
  }

  .search-modal__close:hover {
    color: var(--ink);
  }

  #search-modal-container {
    padding: var(--space-5);
    overflow-y: auto;
    flex: 1;
  }

  /* Pagefind theme overrides */
  :global(.search-modal .pagefind-ui) {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--ink);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--paper);
    --pagefind-ui-border: var(--rule);
    --pagefind-ui-tag: var(--paper-deep);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 4px;
    --pagefind-ui-font: var(--font-sans);
  }

  :global(.search-modal .pagefind-ui__search-input) {
    font-family: var(--font-sans) !important;
    font-size: var(--step-2) !important;
    padding: var(--space-4) var(--space-5) !important;
    height: auto !important;
  }

  :global(.search-modal .pagefind-ui__result-title) {
    font-family: var(--font-serif) !important;
    font-weight: 500 !important;
  }

  :global(.search-modal .pagefind-ui__result-excerpt) {
    font-family: var(--font-serif) !important;
    line-height: var(--leading-relaxed) !important;
    color: var(--ink-soft) !important;
  }

  :global(.search-modal mark) {
    background: var(--accent-tint) !important;
    color: var(--ink) !important;
  }
</style>
