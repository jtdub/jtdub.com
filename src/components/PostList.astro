---
import type { CollectionEntry } from 'astro:content';
import { postUrl } from '../utils/post-url';
import { zoneLabel } from '../utils/zone';

interface Props {
  posts: CollectionEntry<'posts'>[];
  showZone?: boolean;
}

const { posts, showZone = false } = Astro.props;

// Group posts by year for editorial rhythm.
const byYear = new Map<number, CollectionEntry<'posts'>[]>();
for (const post of posts) {
  const year = post.data.date.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<div class="post-list">
  {
    years.map((year) => {
      const items = byYear.get(year)!;
      return (
      <section class="post-list__year">
        <header class="post-list__year-head">
          <span class="post-list__year-mark">{year}</span>
          <span class="post-list__year-count">
            {items.length} {items.length === 1 ? 'entry' : 'entries'}
          </span>
        </header>
        <ul class="post-list__items">
          {items.map((post) => {
            const date = post.data.date.toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
            });
            return (
              <li class="post-list__item" data-zone={showZone ? post.data.zone : undefined}>
                <a href={postUrl(post)}>
                  <time datetime={post.data.date.toISOString()}>{date}</time>
                  {showZone && (
                    <span class="post-list__zone">
                      {zoneLabel(post.data.zone)}
                    </span>
                  )}
                  <h3 class="post-list__title">{post.data.title}</h3>
                  {post.data.tags.length > 0 && (
                    <span class="post-list__tags">
                      {post.data.tags.slice(0, 3).join(' · ')}
                    </span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    );})
  }
</div>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-9);
  }

  .post-list__year {
    display: grid;
    grid-template-columns: minmax(0, 160px) 1fr;
    gap: var(--space-7);
    align-items: start;
  }

  .post-list__year-head {
    position: sticky;
    top: calc(var(--space-8) + 20px);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-4);
  }

  .post-list__year-mark {
    font-family: var(--font-serif);
    font-size: var(--step-5);
    font-weight: 300;
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    color: var(--accent);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
    font-variant-numeric: lining-nums tabular-nums;
  }

  .post-list__year-count {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--ink-faint);
    font-weight: 500;
  }

  .post-list__items {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--rule);
  }

  .post-list__item {
    border-bottom: 1px solid var(--rule);
  }

  .post-list__item a {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    column-gap: var(--space-5);
    row-gap: var(--space-1);
    padding: var(--space-5) 0;
    align-items: baseline;
    color: var(--ink);
    transition: background 180ms ease;
  }

  .post-list__item a:hover {
    text-decoration: none;
  }

  .post-list__item a:hover .post-list__title {
    color: var(--accent-deep);
  }

  .post-list__item time {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-snug);
    color: var(--ink-faint);
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
    font-weight: 500;
    grid-column: 1;
    grid-row: 1 / span 2;
  }

  .post-list__zone {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    grid-column: 2;
    grid-row: 1;
    margin-bottom: 0;
  }

  .post-list__title {
    font-family: var(--font-serif);
    font-size: var(--step-3);
    line-height: var(--leading-snug);
    font-weight: 400;
    letter-spacing: var(--tracking-snug);
    color: var(--ink);
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 40;
    grid-column: 2;
    transition: color 180ms ease;
  }

  .post-list__tags {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--ink-faint);
    letter-spacing: var(--tracking-snug);
    grid-column: 2;
  }

  /* When showing zone badges, make room for it above the title */
  .post-list__item[data-zone] .post-list__title {
    grid-row: 2;
  }

  @media (max-width: 720px) {
    .post-list__year {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .post-list__year-head {
      position: static;
      padding-top: 0;
    }
    .post-list__year-mark {
      font-size: var(--step-4);
    }
    .post-list__item a {
      grid-template-columns: 1fr;
      row-gap: var(--space-2);
    }
    .post-list__item time {
      grid-column: 1;
      grid-row: 1;
    }
    .post-list__zone {
      grid-row: 2;
    }
    .post-list__title {
      grid-column: 1;
      grid-row: 3;
      font-size: var(--step-2);
    }
    .post-list__tags {
      grid-column: 1;
      grid-row: 4;
    }
  }
</style>
