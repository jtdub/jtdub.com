---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search — jtdub.com">
  <section class="search-page">
    <header class="search-page__header">
      <h1 class="search-page__title">Search</h1>
    </header>

    <div id="search-container"></div>
  </section>
</BaseLayout>

<style>
  .search-page {
    max-width: var(--shell-max);
    margin: 0 auto;
    padding: var(--space-9) var(--gutter) var(--space-10);
  }

  .search-page__header {
    margin-bottom: var(--space-7);
  }

  .search-page__title {
    font-family: var(--font-serif);
    font-size: clamp(var(--step-4), 5vw, var(--step-6));
    font-weight: 400;
    letter-spacing: var(--tracking-tight);
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 0;
  }

  /* Pagefind UI theme overrides */
  :global(.pagefind-ui) {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--ink);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--paper);
    --pagefind-ui-border: var(--rule);
    --pagefind-ui-tag: var(--paper-deep);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 4px;
    --pagefind-ui-font: var(--font-sans);
  }

  :global(.pagefind-ui .pagefind-ui__search-input) {
    font-family: var(--font-sans);
    font-size: var(--step-2);
    padding: var(--space-4) var(--space-5);
    height: auto;
  }

  :global(.pagefind-ui .pagefind-ui__result-title) {
    font-family: var(--font-serif);
    font-weight: 500;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 0;
  }

  :global(.pagefind-ui .pagefind-ui__result-excerpt) {
    font-family: var(--font-serif);
    line-height: var(--leading-relaxed);
    color: var(--ink-soft);
  }

  :global(.pagefind-ui mark) {
    background: var(--accent-tint);
    color: var(--ink);
  }
</style>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', function () {
    new PagefindUI({
      element: '#search-container',
      showSubResults: true,
      showImages: false,
    });

    var container = document.getElementById('search-container');
    var input = container && container.querySelector('.pagefind-ui__search-input');
    if (input) input.focus();

    var params = new URLSearchParams(window.location.search);
    var query = params.get('q');
    if (query && input) {
      input.value = query;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    }
  });
</script>
