---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/article.css';
---

<BaseLayout
  title="About — jtdub.com"
  description="James Williams — network automation engineer, anthropologist, scientific diver, and field researcher."
>
  <article class="article">
    <header class="article__header">
      <p class="article__eyebrow">About</p>
      <h1 class="article__title">James Williams</h1>
    </header>

    <div class="article__body">
      <p>
        Experienced Network Automation Engineer, Linux Systems Administrator, and
        Python Developer with over 20 years in IT infrastructure, network
        engineering, and automation. Skilled in designing and deploying automation
        platforms, mentoring teams, and building innovative solutions for complex
        environments.
      </p>

      <p>
        In addition to my technical career, I contribute to environmental and
        cultural research as a Water Quality Monitor, Scientific Diver, and
        Avocational Anthropologist, with published work in archaeology and field
        experience on international expeditions. Currently pursuing a B.A. in
        Anthropology with a concentration in Environmental Sustainability.
      </p>

      <hr />

      <h2>Professional Development</h2>

      <p>
        Active engagement with professional organizations and fieldwork training
        supports ongoing development in archaeological methods, environmental
        research, and community science approaches.
      </p>
    </div>
  </article>
</BaseLayout>
